          "editorMode": "code",
          "expr": "clickhouse_backup_last_create_remote_duration{namespace=~\"$namespace\", pod=~\"$pod\"} / 1e9",
          "legendFormat": "{{pod}}",
          "range": true,
          "refId": "A"
        }
      ],
